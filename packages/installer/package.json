{
  "name": "codex-plusplus",
  "version": "0.0.1",
  "description": "Installer CLI for codex-plusplus tweak system",
  "type": "module",
  "bin": {
    "codex-plusplus": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-assets",
    "copy-assets": "node ./scripts/copy-assets.mjs",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@electron/asar": "^3.4.0",
    "kleur": "^4.1.5",
    "plist": "^3.1.0",
    "prompts": "^2.4.2",
    "sade": "^1.8.1"
  },
  "devDependencies": {
    "@types/plist": "^3.0.5",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
